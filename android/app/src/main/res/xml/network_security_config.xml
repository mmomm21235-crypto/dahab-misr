<?xml version="1.0" encoding="utf-8"?>
<!--
    Dahab Misr - Network Security Configuration
    Team 4: Mobile APK Security
    Enforces TLS 1.2+, certificate pinning, and blocks cleartext traffic.
-->
<network-security-config>

    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        Certificate Pinning for API endpoints.
        Replace the pin-sha256 values with your actual server certificate pins.
        Generate pins using: openssl s_client -connect yourapi.com:443 | openssl x509 -pubkey -noout | openssl rsa -pubin -outform der | openssl dgst -sha256 -binary | base64

        For backup pins, also pin the intermediate CA or cross-signed cert.
        Keep at least 2 pins per domain (current + backup).
    -->
    <domain-config>
        <!-- Primary API Domain -->
        <domain includeSubdomains="true">dahabmisr.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- Primary Pin (replace with your actual pin) -->
            <pin digest="SHA-256">YOUR_PRIMARY_PIN_BASE64_HERE</pin>
            <!-- Backup Pin (replace with your actual pin) -->
            <pin digest="SHA-256">YOUR_BACKUP_PIN_BASE64_HERE</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- API Backend -->
    <domain-config>
        <domain includeSubdomains="true">api.dahabmisr.com</domain>
        <pin-set expiration="2027-01-01">
            <pin digest="SHA-256">YOUR_API_PIN_BASE64_HERE</pin>
            <pin digest="SHA-256">YOUR_API_BACKUP_PIN_BASE64_HERE</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Staging / Development (Only for debug builds, restrict in production) -->
    <!--
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">staging.dahabmisr.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    -->

</network-security-config>
