<?xml version="1.0" encoding="utf-8"?>
<!--
    Dahab Misr - Network Security Configuration
    Team 4: Mobile APK Security
    Enforces TLS 1.2+, certificate pinning, and blocks cleartext traffic.
-->
<network-security-config>

    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        Certificate Pinning for Vercel-hosted API endpoints.
        Vercel uses DigiCert Global Root G2 /altimore CyberTrust Root.
        Pins target the Vercel edge certificate chain.

        Generate pins using:
        openssl s_client -connect dahab-misr.vercel.app:443 -servername dahab-misr.vercel.app </dev/null 2>/dev/null \
          | openssl x509 -pubkey -noout \
          | openssl pkey -pubin -outform der \
          | openssl dgst -sha256 -binary \
          | base64

        For backup pins, also pin the intermediate CA or cross-signed cert.
    -->
    <domain-config>
        <!-- Primary app domain (Vercel) -->
        <domain includeSubdomains="true">dahab-misr.vercel.app</domain>
        <pin-set expiration="2027-01-01">
            <!-- Primary Pin: Vercel Edge Certificate (DigiCert Global Root G2) -->
            <pin digest="SHA-256">yzsusJqFBKh2vithSfCb/BWO0UGYfpFfXATB9Rv8+Sc=</pin>
            <!-- Backup Pin: Baltimore CyberTrust Root (cross-sign) -->
            <pin digest="SHA-256">lwFqfMsKfIJoJm4heo5wLEyLmx5sJU+0B1H5dFYCq/c=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Custom domain (if configured) -->
    <domain-config>
        <domain includeSubdomains="true">dahabmisr.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- Primary Pin: DigiCert Global Root G2 -->
            <pin digest="SHA-256">yzsusJqFBKh2vithSfCb/BWO0UGYfpFfXATB9Rv8+Sc=</pin>
            <!-- Backup Pin: Baltimore CyberTrust Root -->
            <pin digest="SHA-256">lwFqfMsKfIJoJm4heo5wLEyLmx5sJU+0B1H5dFYCq/c=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Staging / Development (Only for debug builds, restrict in production) -->
