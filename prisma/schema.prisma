generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  alerts      Alert[]
  alertHistory AlertHistory[]
  settings    UserSettings?
  portfolio   PortfolioHolding[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  theme            String   @default("system")
  language         String   @default("ar")
  notifications    Boolean  @default(true)
  currency         String   @default("EGP")
  pushSubscription String?
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Alert {
  id           String   @id @default(cuid())
  userId       String
  karat        String
  targetPrice  Float
  condition    String
  isActive     Boolean  @default(true)
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  triggeredAt  DateTime?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

model GoldPrice {
  id          String   @id @default(cuid())
  karat24Buy  Float
  karat24Sell Float
  karat21Buy  Float
  karat21Sell Float
  karat18Buy  Float
  karat18Sell Float
  poundBuy    Float
  poundSell   Float
  dollarPrice Float
  change24    Float?
  change21    Float?
  change18    Float?
  changePound Float?
  source      String   @default("ذهب مصر")
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  phone     String
  whatsapp  String
  address   String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model NewsArticle {
  id        String   @id @default(cuid())
  title     String
  summary   String
  content   String
  category  String
  source    String
  imageUrl  String?
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([category])
}

model PortfolioHolding {
  id        String   @id @default(cuid())
  userId    String
  name      String
  karat     Int
  weight    Float
  buyPrice  Float
  buyDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AlertHistory {
  id           String   @id @default(cuid())
  userId       String?
  karat        String
  targetPrice  Float
  currentPrice Float
  condition    String
  triggeredAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([triggeredAt])
  @@index([karat])
  @@index([userId])
}
