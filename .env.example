# PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth.js
AUTH_SECRET="generate-a-random-64-char-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Gold Price API (https://www.goldapi.io/)
GOLD_API_KEY=""

# News API (https://newsdata.io/)
NEWS_API_KEY=""

# Encryption key for sensitive data (phone numbers)
ENCRYPTION_KEY="generate-a-random-secret"

# Admin email (server-side only, never expose to client)
ADMIN_EMAIL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ذهب مصر"

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""
